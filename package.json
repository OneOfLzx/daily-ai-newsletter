{
  "name": "daily-ai-newsletter",
  "version": "1.0.0",
  "description": "Daily AI Newsletter Generator",
  "main": "src/cli/index.js",
  "type": "module",
  "bin": {
    "daily-ai-newsletter": "./src/cli/index.js"
  },
  "private": true,
  "scripts": {
    "build": "bun run build:linux && bun run build:mac && bun run build:windows",
    "build:linux": "bun build --compile --target=bun-linux-x64 ./src/cli/index.js --outfile ./dist/daily-ai-newsletter-linux",
    "build:mac": "bun build --compile --target=bun-darwin-arm64 ./src/cli/index.js --outfile ./dist/daily-ai-newsletter-mac",
    "build:windows": "bun build --compile --target=bun-windows-x64 ./src/cli/index.js --outfile ./dist/daily-ai-newsletter-windows.exe",
    "generate": "bun run src/cli/index.js generate",
    "deploy": "bun run src/deploy/index.js",
    "all": "bun run src/cli/index.js generate && bun run src/deploy/index.js",
    "test": "bun test",
    "test:github-mcp": "bun run scripts/test-github-repo-mcp-summary.js"
  },
  "devDependencies": {
    "bun": "^1.3.11"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/rest": "^22.0.1",
    "cheerio": "^1.2.0",
    "gh-pages": "^6.3.0",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.1",
    "openai": "^6.33.0",
    "puppeteer": "^24.40.0",
    "rss-parser": "^3.13.0",
    "yaml": "^2.8.3"
  }
}
